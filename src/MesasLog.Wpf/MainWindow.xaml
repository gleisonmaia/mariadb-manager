<Window x:Class="MesasLog.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MariaDB Manager"
        Loaded="MainWindow_OnLoaded"
        Icon="pack://application:,,,/AppIcon.ico"
        Height="720" Width="960"
        MinHeight="720" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.WindowBg}"
        FontFamily="Segoe UI">
    <Window.InputBindings>
        <KeyBinding Key="F11" Modifiers="Control+Shift" Command="{Binding AlternarAbaAvancadaCommand}" />
    </Window.InputBindings>
    <DockPanel Margin="8">
        <TabControl>
            <TabItem Header="Análise de logs">
                <TabControl Margin="0,2,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            ItemContainerStyle="{StaticResource SubTabItemStyle}">
                    <TabItem Header="Processamento">
                <Border Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16"
                        Margin="0,4,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Ações"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Margin="0,0,0,10" />
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="220" />
                            </Grid.ColumnDefinitions>
                            <GroupBox Grid.Column="0" Header="Processar binlog" Padding="12,10,12,12"
                                      BorderBrush="{StaticResource Brush.Border}"
                                      ToolTip="Lê o binlog e grava eventos em binlog_event_log (respeitando checkpoint).">
                                <StackPanel>
                                    <TextBlock Text="Banco a analisar"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               FontSize="12"
                                               Margin="0,0,0,4" />
                                    <TextBox Text="{Binding NomeBancoProcessamento, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,10"
                                             ToolTip="Só eventos ROW deste schema serão processados (nome exato, sem distinção de maiúsculas)." />
                                    <CheckBox Content="Dry-run (sem gravar)"
                                              IsChecked="{Binding DryRunProcessamento}"
                                              Margin="0,0,0,10" />
                                    <Button Content="Processar binlog"
                                            Command="{Binding ProcessarBinlogCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Passo a passo"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Margin="0,0,0,8" />
                        <Border Background="#0F172A"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBox x:Name="PassoAPassoTextBox"
                                     Text="{Binding PassoAPasso, Mode=OneWay}"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Foreground="#E2E8F0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="12"
                                     TextChanged="PassoAPassoTextBox_OnTextChanged" />
                        </Border>
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="Consulta de eventos">
                <!-- Filtros (0) | barra Buscar (1) | grade com mais peso (2) | rodapé (3) -->
                <Grid Margin="0,2,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" MinHeight="340" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,6">
                        <StackPanel>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="100" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" MinWidth="100" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" MinWidth="120" />
                                </Grid.ColumnDefinitions>

                                <GroupBox Grid.Column="0" Header="Origem" Padding="6,4,6,6" Margin="0,0,0,4"
                                          VerticalAlignment="Top">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Banco" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,2" />
                                        <TextBox Grid.Row="1" Padding="4,2" MinHeight="24"
                                                 Text="{Binding BancoFiltro, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,4"
                                                 ToolTip="Nome exato do banco (correspondência igual, não contém texto)." />
                                        <TextBlock Grid.Row="2" Text="Tabela" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,2" />
                                        <TextBox Grid.Row="3" Padding="4,2" MinHeight="24"
                                                 Text="{Binding TabelaFiltro, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Grid.Column="2" Header="Período" Padding="6,4,6,6" Margin="0,0,0,4"
                                          VerticalAlignment="Top"
                                          ToolTip="Data e hora (24 h). Hora vazia: De = 00:00:00, Até = fim do dia.">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="110" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" MinWidth="88" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                   Text="De" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,2" />
                                        <DatePicker Grid.Row="1" Grid.Column="0"
                                                    SelectedDate="{Binding DataInicio}" Margin="0,0,0,6" MinHeight="30"
                                                    VerticalAlignment="Center" VerticalContentAlignment="Center" />
                                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="0,0,0,6">
                                            <TextBlock Text="Hora" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBox Padding="4,2" MinHeight="30" Width="92" MaxWidth="92"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding HoraInicioTexto, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas"
                                                     ToolTip="HH:mm ou HH:mm:ss. Vazio = 00:00:00." />
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                                   Text="Até" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,2" />
                                        <DatePicker Grid.Row="3" Grid.Column="0"
                                                    SelectedDate="{Binding DataFim}" Margin="0,0,0,0" MinHeight="30"
                                                    VerticalAlignment="Center" VerticalContentAlignment="Center" />
                                        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Hora" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBox Padding="4,2" MinHeight="30" Width="92" MaxWidth="92"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding HoraFimTexto, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas"
                                                     ToolTip="HH:mm ou HH:mm:ss. Vazio = até o último instante do dia." />
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>

                                <StackPanel Grid.Column="4" VerticalAlignment="Top">
                                    <GroupBox Header="Tipo" Padding="6,4,6,6" Margin="0,0,0,6"
                                              ToolTip="INSERT, UPDATE ou DELETE. Vazio = todos.">
                                        <ComboBox ItemsSource="{Binding TiposOperacaoLista}"
                                                  SelectedItem="{Binding TipoOperacaoSelecionado}"
                                                  MinHeight="30"
                                                  VerticalAlignment="Top" />
                                    </GroupBox>
                                    <GroupBox Header="Texto em query_sql" Padding="6,4,6,6" Margin="0,0,0,0"
                                              ToolTip="LIKE %texto% na coluna query_sql.">
                                        <TextBox Text="{Binding TextoQuerySql, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4,2" MinHeight="28" />
                                    </GroupBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <GroupBox Grid.Row="1" Header="Ordem, página e busca" Padding="6,4,6,6" Margin="0,0,0,6">
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="Ordenar:" VerticalAlignment="Center" Margin="0,0,4,4" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" />
                            <ComboBox Width="110" Margin="0,0,10,4" MinHeight="24"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding OrdenacaoOpcoes}"
                                      SelectedItem="{Binding Ordenacao}" />
                            <CheckBox Content="Desc."
                                      IsChecked="{Binding OrdenacaoDescendente}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,4"
                                      ToolTip="Ordem decrescente" />
                            <TextBlock Text="Itens/pág.:" VerticalAlignment="Center" Margin="0,0,4,4" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" />
                            <TextBox Text="{Binding PageSize, UpdateSourceTrigger=PropertyChanged}"
                                     Width="40" MinHeight="24" Margin="0,0,10,4"
                                     HorizontalContentAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Button Content="Buscar"
                                    Command="{Binding BuscarEventosCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="10,4" MinHeight="26" Margin="0,0,6,4" />
                            <Button Content="Cancelar"
                                    Command="{Binding CancelarConsultaCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Padding="10,4" MinHeight="26" Margin="0,0,8,4" />
                            <Border VerticalAlignment="Center" Padding="6,3" Margin="0,0,0,4"
                                    Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Consultando}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Consultando…" FontSize="11" Foreground="#92400E" />
                            </Border>
                        </WrapPanel>
                    </GroupBox>

                    <Border Grid.Row="2"
                            Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <DataGrid ItemsSource="{Binding Eventos}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="False"
                                  EnableRowVirtualization="True"
                                  Margin="1"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ToolTip="Clique numa célula para copiar o valor para a área de transferência."
                                  PreviewMouseLeftButtonUp="EventosDataGrid_OnPreviewMouseLeftButtonUp">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data"
                                                    Binding="{Binding DataEvento, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                                    Width="128" />
                                <DataGridTextColumn Header="Banco" Binding="{Binding Banco}" Width="88" />
                                <DataGridTextColumn Header="Tabela" Binding="{Binding Tabela}" Width="88" />
                                <DataGridTextColumn Header="Op." Binding="{Binding TipoOperacao}" Width="56" />
                                <DataGridTextColumn Header="query_sql"
                                                    Binding="{Binding QuerySql}"
                                                    MinWidth="200"
                                                    Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="3"
                            Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6"
                            Margin="0,6,0,0">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       FontSize="12">
                                <Run Text="Total de registros: " FontWeight="SemiBold" />
                                <Run Text="{Binding TotalRegistros, Mode=OneWay}" />
                                <Run Text="   •   Página " Foreground="{StaticResource Brush.TextSecondary}" />
                                <Run Text="{Binding TextoPaginacao, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Button DockPanel.Dock="Right"
                                    Content="Última »"
                                    Command="{Binding UltimaPaginaCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Padding="10,5"
                                    Margin="6,0,0,0" />
                            <Button DockPanel.Dock="Right"
                                    Content="Próxima →"
                                    Command="{Binding ProximaPaginaCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Padding="10,5"
                                    Margin="6,0,0,0" />
                            <Button DockPanel.Dock="Right"
                                    Content="← Anterior"
                                    Command="{Binding PaginaAnteriorCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Padding="10,5"
                                    Margin="6,0,0,0" />
                            <Button DockPanel.Dock="Right"
                                    Content="« Primeira"
                                    Command="{Binding PrimeiraPaginaCommand}"
                                    Style="{StaticResource ToolbarButton}"
                                    Padding="10,5" />
                        </DockPanel>
                    </Border>
                </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Backup/Restauração">
                <Border Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,4,0,0">
                    <TabControl Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                ItemContainerStyle="{StaticResource SubTabItemStyle}">

                        <TabItem Header="Origem (Backup)">
                            <DockPanel LastChildFill="True" Margin="0,8,0,0">
                                <ScrollViewer DockPanel.Dock="Top"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="380">
                                    <GroupBox Padding="12,10,12,12"
                                              BorderBrush="{StaticResource Brush.Border}"
                                              Header="Conexão — origem">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="136" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" MinWidth="120" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="112" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo Banco" Style="{StaticResource FilterLabel}" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Servidor" Style="{StaticResource FilterLabel}" />
                                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Porta" Style="{StaticResource FilterLabel}" />
                                                <ComboBox Grid.Row="1" Grid.Column="0"
                                                          ItemsSource="{Binding TiposBancoBackup}"
                                                          SelectedItem="{Binding TipoBancoOrigem}"
                                                          MinWidth="120"
                                                          ToolTip="MySQL ou MariaDB (sem valor padrão)." />
                                                <TextBox Grid.Row="1" Grid.Column="2"
                                                         Text="{Binding ServidorOrigem, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1" Grid.Column="4"
                                                         Text="{Binding PortaOrigemTexto, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                            <TextBlock Text="Banco" Style="{StaticResource FilterLabel}" />
                                            <TextBox Text="{Binding BancoOrigem, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,10" />
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Usuário" Style="{StaticResource FilterLabel}" />
                                                    <TextBox Text="{Binding UsuarioOrigem, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Senha" Style="{StaticResource FilterLabel}" />
                                                    <TextBox Text="{Binding SenhaOrigem, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>
                                            <Button Content="Realizar Backup"
                                                    Command="{Binding RealizarBackupOrigemCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProcessandoBackupOrigem}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ProcessandoRestauracao}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </GroupBox>
                                </ScrollViewer>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Passo a passo"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           Margin="0,8,0,8" />
                                <Border Background="#0F172A"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBox Text="{Binding PassoPassoBackupOrigem, Mode=OneWay}"
                                             IsReadOnly="True"
                                             MinHeight="160"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Foreground="#E2E8F0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="12"
                                             TextChanged="PassoAPassoTextBox_OnTextChanged" />
                                </Border>
                            </DockPanel>
                        </TabItem>

                        <TabItem Header="Destino (Restauração)">
                            <DockPanel LastChildFill="True" Margin="0,8,0,0">
                                <ScrollViewer DockPanel.Dock="Top"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="380">
                                    <GroupBox Padding="12,10,12,12"
                                              BorderBrush="{StaticResource Brush.Border}"
                                              Header="Conexão e arquivo — destino">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="136" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" MinWidth="120" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="112" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo Banco" Style="{StaticResource FilterLabel}" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Servidor" Style="{StaticResource FilterLabel}" />
                                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Porta" Style="{StaticResource FilterLabel}" />
                                                <ComboBox Grid.Row="1" Grid.Column="0"
                                                          ItemsSource="{Binding TiposBancoBackup}"
                                                          SelectedItem="{Binding TipoBancoDestino}"
                                                          MinWidth="120" />
                                                <TextBox Grid.Row="1" Grid.Column="2"
                                                         Text="{Binding ServidorDestino, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1" Grid.Column="4"
                                                         Text="{Binding PortaDestinoTexto, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                            <TextBlock Text="Banco" Style="{StaticResource FilterLabel}" />
                                            <TextBox Text="{Binding BancoDestino, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,10" />
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Usuário" Style="{StaticResource FilterLabel}" />
                                                    <TextBox Text="{Binding UsuarioDestino, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Senha" Style="{StaticResource FilterLabel}" />
                                                    <TextBox Text="{Binding SenhaDestino, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Arquivo para importar" Style="{StaticResource FilterLabel}" />
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding ArquivoSqlDestino, UpdateSourceTrigger=PropertyChanged}"
                                                         IsReadOnly="True"
                                                         ToolTip="Apenas arquivos .sql" />
                                                <Button Grid.Column="2"
                                                        Content="Procurar…"
                                                        Command="{Binding SelecionarArquivoSqlDestinoCommand}"
                                                        Style="{StaticResource ToolbarButton}"
                                                        Padding="12,6"
                                                        MinHeight="30" />
                                            </Grid>
                                            <Button Content="Restaurar Banco"
                                                    Command="{Binding RestaurarBancoDestinoCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProcessandoRestauracao}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ProcessandoBackupOrigem}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </GroupBox>
                                </ScrollViewer>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Passo a passo"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           Margin="0,8,0,8" />
                                <Border Background="#0F172A"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBox Text="{Binding PassoPassoRestauracao, Mode=OneWay}"
                                             IsReadOnly="True"
                                             MinHeight="160"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Foreground="#E2E8F0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="12"
                                             TextChanged="PassoAPassoTextBox_OnTextChanged" />
                                </Border>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </TabItem>

            <TabItem Header="Avançado"
                     IsEnabled="{Binding AbaAvancadaDesbloqueada}"
                     ToolTip="Bloqueada. Ctrl+Shift+F11 libera ou volta a bloquear esta aba.">
                <Border Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16"
                        Margin="0,4,0,0">
                    <StackPanel>
                        <GroupBox Header="Replay" Padding="12,10,12,12" Margin="0,0,0,16"
                                  BorderBrush="{StaticResource Brush.Border}"
                                  ToolTip="Reconstrói tabelas log_* a partir de binlog_event_log.">
                            <StackPanel>
                                <CheckBox Content="Dry-run replay"
                                          IsChecked="{Binding DryRunReplay}"
                                          Margin="0,0,0,10" />
                                <Button Content="Replay (reconstruir log_*)"
                                        Command="{Binding ReplayCommand}"
                                        Style="{StaticResource ToolbarButton}"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </GroupBox>
                        <TextBlock Text="Esquema e dados de referência"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Margin="0,0,0,8" />
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Margin="0,0,0,14"
                                   Text="Reaplica o script mesas.sql (tabelas log_* e objetos relacionados) no banco configurado. Útil após atualizar o arquivo ou para alinhar o ambiente." />
                        <Button Content="Reaplicar esquema / mesas.sql"
                                Command="{Binding InicializarEsquemaCommand}"
                                Style="{StaticResource ToolbarButton}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
